# Google Apps Script Web App base URL (no trailing slash)
# VITE_GAS_BASE_URL=https://script.google.com/macros/s/XXXX/exec

# "true" | "false" — if unset: dev uses mock when GAS is missing; prod build uses GAS if URL set
# VITE_USE_MOCK=true

# Optional, must match Apps Script script property SUBMIT_TOKEN if you set that
# VITE_SUBMIT_TOKEN=your-secret
